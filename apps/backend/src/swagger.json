{
  "openapi": "3.0.0",
  "info": {
    "title": "M. Finnance AI API",
    "description": "API for managing finances with AI-powered insights",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3001",
      "description": "Development server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "paths": {
    "/api/users/register": {
      "post": {
        "summary": "Register a new user",
        "tags": ["Users"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string",
                    "format": "password"
                  }
                },
                "required": ["name", "email", "password"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created successfully"
          },
          "400": {
            "description": "Invalid request"
          }
        }
      }
    },
    "/api/users/login": {
      "post": {
        "summary": "Login user",
        "tags": ["Users"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string",
                    "format": "password"
                  }
                },
                "required": ["email", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful"
          },
          "401": {
            "description": "Invalid credentials"
          }
        }
      }
    },
    "/api/users/profile": {
      "get": {
        "summary": "Get user profile",
        "tags": ["Users"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "User profile"
          },
          "401": {
            "description": "Not authorized"
          }
        }
      },
      "put": {
        "summary": "Update user profile",
        "tags": ["Users"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "dateOfBirth": {
                    "type": "string",
                    "format": "date"
                  },
                  "phone": {
                    "type": "string"
                  },
                  "language": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Profile updated"
          },
          "401": {
            "description": "Not authorized"
          }
        }
      }
    },
    "/api/transactions": {
      "post": {
        "summary": "Create a new transaction",
        "tags": ["Transactions"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "account": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "category": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "amount": {
                    "type": "number"
                  },
                  "type": {
                    "type": "string",
                    "enum": ["income", "expense", "investment"]
                  },
                  "description": {
                    "type": "string"
                  },
                  "date": {
                    "type": "string",
                    "format": "date-time"
                  }
                },
                "required": [
                  "account",
                  "category",
                  "amount",
                  "type",
                  "description"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Transaction created"
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Not authorized"
          }
        }
      },
      "get": {
        "summary": "Get user transactions",
        "tags": ["Transactions"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "query",
            "name": "type",
            "schema": {
              "type": "string",
              "enum": ["income", "expense", "investment"]
            }
          },
          {
            "in": "query",
            "name": "category",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "startDate",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "in": "query",
            "name": "endDate",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "in": "query",
            "name": "account",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "page",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "integer",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of transactions"
          },
          "401": {
            "description": "Not authorized"
          }
        }
      }
    },
    "/api/reports/generate": {
      "get": {
        "summary": "Generate financial report",
        "tags": ["Reports"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "in": "query",
            "name": "period",
            "schema": {
              "type": "string",
              "enum": ["month", "quarter", "year"],
              "default": "month"
            }
          },
          {
            "in": "query",
            "name": "format",
            "schema": {
              "type": "string",
              "enum": ["pdf", "excel"],
              "default": "pdf"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Report file",
            "content": {
              "application/pdf": {},
              "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet": {}
            }
          },
          "401": {
            "description": "Not authorized"
          }
        }
      }
    },
    "/api/reports/insights": {
      "get": {
        "summary": "Get AI financial insights",
        "tags": ["Reports"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "AI insights"
          },
          "401": {
            "description": "Not authorized"
          }
        }
      }
    },
    "/api/planning/plan": {
      "get": {
        "summary": "Get financial plan (50/30/20)",
        "tags": ["Planning"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Plano financeiro com alocação e metas sugeridas" },
          "401": { "description": "Not authorized" }
        }
      }
    },
    "/api/planning/simulate": {
      "get": {
        "summary": "Simulate savings scenario",
        "tags": ["Planning"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "in": "query", "name": "savingsPercent", "schema": { "type": "number" }, "description": "Percentual de poupança (0-100)" },
          { "in": "query", "name": "months", "schema": { "type": "integer" }, "description": "Número de meses" }
        ],
        "responses": {
          "200": { "description": "Projeção de economia" },
          "401": { "description": "Not authorized" }
        }
      }
    },
    "/api/planning/adherence": {
      "get": {
        "summary": "Get adherence to financial plan",
        "tags": ["Planning"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Aderência 50/30/20 e sugestões" },
          "401": { "description": "Not authorized" }
        }
      }
    },
    "/api/consultant/sessions": {
      "post": {
        "summary": "Create a new consultant chat session",
        "tags": ["Consultant"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Sessão criada",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "sessionId": { "type": "string" },
                    "title": { "type": "string", "example": "Nova conversa" }
                  }
                }
              }
            }
          },
          "401": { "description": "Not authorized" }
        }
      },
      "get": {
        "summary": "List consultant chat sessions",
        "tags": ["Consultant"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Lista de sessões do usuário",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "sessions": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "_id": { "type": "string" },
                          "title": { "type": "string" },
                          "createdAt": { "type": "string", "format": "date-time" },
                          "updatedAt": { "type": "string", "format": "date-time" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "description": "Not authorized" }
        }
      }
    },
    "/api/consultant/sessions/{id}": {
      "get": {
        "summary": "Get consultant session with messages",
        "tags": ["Consultant"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "in": "path", "name": "id", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Sessão com mensagens",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "session": {
                      "type": "object",
                      "properties": {
                        "_id": { "type": "string" },
                        "title": { "type": "string" },
                        "messages": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "role": { "type": "string", "enum": ["user", "assistant"] },
                              "content": { "type": "string" },
                              "createdAt": { "type": "string", "format": "date-time" }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "description": "Not authorized" },
          "404": { "description": "Sessão não encontrada" }
        }
      }
    },
    "/api/consultant/chat": {
      "post": {
        "summary": "Send message to financial consultant",
        "tags": ["Consultant"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["message"],
                "properties": {
                  "message": { "type": "string", "maxLength": 4000, "description": "Mensagem do usuário" },
                  "history": {
                    "type": "array",
                    "description": "Histórico opcional (ignorado se sessionId for enviado)",
                    "items": {
                      "type": "object",
                      "properties": {
                        "role": { "type": "string", "enum": ["user", "assistant"] },
                        "content": { "type": "string" }
                      }
                    }
                  },
                  "useUserContext": { "type": "boolean", "default": true, "description": "Incluir dados financeiros do usuário no contexto da IA" },
                  "sessionId": { "type": "string", "description": "ID da sessão para persistir e usar histórico" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Resposta do consultor",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "reply": { "type": "string" },
                    "sessionId": { "type": "string", "description": "Presente quando a mensagem foi persistida na sessão" }
                  }
                }
              }
            }
          },
          "400": { "description": "Mensagem inválida ou vazia" },
          "401": { "description": "Not authorized" },
          "404": { "description": "Sessão não encontrada (quando sessionId enviado)" }
        }
      }
    },
    "/api/whatsapp/webhook": {
      "post": {
        "summary": "Webhook Twilio (mensagens WhatsApp recebidas)",
        "tags": ["WhatsApp"],
        "description": "Endpoint público. Validado via X-Twilio-Signature. Body: application/x-www-form-urlencoded (From, Body, etc.). Resposta: TwiML.",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "From": { "type": "string", "example": "whatsapp:+5511999999999" },
                  "Body": { "type": "string", "example": "almoço 45,90" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "TwiML de resposta ao WhatsApp" },
          "400": { "description": "Header X-Twilio-Signature ausente" },
          "403": { "description": "Assinatura Twilio inválida" },
          "500": { "description": "Validação não configurada (TWILIO_AUTH_TOKEN)" }
        }
      }
    }
  }
}
